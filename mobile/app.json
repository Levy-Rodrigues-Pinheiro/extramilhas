{
  "expo": {
    "name": "Milhas Extras",
    "slug": "milhasextras",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "milhasextras",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.milhasextras.app",
      "associatedDomains": ["applinks:milhasextras.com.br"],
      "infoPlist": {
        "NSUserActivityTypes": [
          "com.milhasextras.app.check-wallet",
          "com.milhasextras.app.view-arbitrage",
          "com.milhasextras.app.view-alerts"
        ],
        "NSSiriUsageDescription": "Permitir Siri consultar suas milhas e oportunidades de arbitragem.",
        "CFBundleShortcutItems": [
          {
            "UIApplicationShortcutItemType": "com.milhasextras.app.wallet",
            "UIApplicationShortcutItemTitle": "Minha carteira",
            "UIApplicationShortcutItemSubtitle": "Ver valor total",
            "UIApplicationShortcutItemIconType": "UIApplicationShortcutIconTypeHome"
          },
          {
            "UIApplicationShortcutItemType": "com.milhasextras.app.arbitrage",
            "UIApplicationShortcutItemTitle": "Oportunidades",
            "UIApplicationShortcutItemSubtitle": "Bônus ativos agora",
            "UIApplicationShortcutItemIconType": "UIApplicationShortcutIconTypeMarkLocation"
          },
          {
            "UIApplicationShortcutItemType": "com.milhasextras.app.calculator",
            "UIApplicationShortcutItemTitle": "Calculadora",
            "UIApplicationShortcutItemSubtitle": "Vale a pena transferir?",
            "UIApplicationShortcutItemIconType": "UIApplicationShortcutIconTypeCompose"
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.milhasextras.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "milhasextras.com.br",
              "pathPrefix": "/r"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "shortcuts": [
        {
          "iconResource": "@drawable/ic_shortcut_wallet",
          "shortLabel": "Minha carteira",
          "longLabel": "Ver valor total da carteira",
          "intent": {
            "action": "android.intent.action.VIEW",
            "data": "milhasextras://wallet"
          }
        },
        {
          "iconResource": "@drawable/ic_shortcut_arbitrage",
          "shortLabel": "Oportunidades",
          "longLabel": "Bônus de transferência ativos",
          "intent": {
            "action": "android.intent.action.VIEW",
            "data": "milhasextras://arbitrage"
          }
        },
        {
          "iconResource": "@drawable/ic_shortcut_calculator",
          "shortLabel": "Calculadora",
          "longLabel": "Vale a pena transferir?",
          "intent": {
            "action": "android.intent.action.VIEW",
            "data": "milhasextras://transfer-calculator"
          }
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#6366f1"
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "0f700ac6-7e45-40b8-91eb-05c01bc24ee5"
      }
    },
    "owner": "levyrodrigues"
  }
}
