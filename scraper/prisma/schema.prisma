// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// This is a copy of the backend schema - both services share the same database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  PRO
}

enum OfferType {
  PURCHASE
  TRANSFER_BONUS
  AWARD_DISCOUNT
  PROMO
}

enum OfferClassification {
  IMPERDIVEL
  BOA
  NORMAL
}

enum AlertType {
  CPM_THRESHOLD
  DESTINATION
  PROGRAM_PROMO
}

enum NotificationChannel {
  PUSH
  EMAIL
  IN_APP
}

model User {
  id                    String           @id @default(uuid())
  email                 String           @unique
  name                  String
  passwordHash          String?
  authProvider          AuthProvider     @default(EMAIL)
  subscriptionPlan      SubscriptionPlan @default(FREE)
  subscriptionExpiresAt DateTime?
  refreshToken          String?
  isAdmin               Boolean          @default(false)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  preferences   UserPreference?
  alerts        Alert[]
  savedOffers   SavedOffer[]
  notifications Notification[]
  milesBalances UserMilesBalance[]
  auditLogs     AuditLog[]         @relation("AdminAuditLogs")

  @@map("users")
}

model UserPreference {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  preferredPrograms      String[]
  preferredOrigins       String[]
  preferredDestinations  String[]
  targetCpm              Decimal  @default(25.00) @db.Decimal(10, 2)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model LoyaltyProgram {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  logoUrl       String?
  websiteUrl    String?
  avgCpmCurrent Decimal  @default(25.00) @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  offers        Offer[]
  priceHistory  PriceHistory[]
  milesBalances UserMilesBalance[]

  @@map("loyalty_programs")
}

model Offer {
  id               String              @id @default(uuid())
  programId        String
  type             OfferType
  title            String
  description      String?
  cpm              Decimal             @db.Decimal(10, 2)
  classification   OfferClassification
  sourceUrl        String?
  affiliateUrl     String?
  startsAt         DateTime?
  expiresAt        DateTime?
  isActive         Boolean             @default(true)
  isDeleted        Boolean             @default(false)
  metadata         Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  program        LoyaltyProgram  @relation(fields: [programId], references: [id])
  savedByUsers   SavedOffer[]
  alertHistories AlertHistory[]

  @@map("offers")
}

model Alert {
  id              String    @id @default(uuid())
  userId          String
  type            AlertType
  conditions      Json
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  history AlertHistory[]

  @@map("alerts")
}

model AlertHistory {
  id      String              @id @default(uuid())
  alertId String
  offerId String?
  sentAt  DateTime            @default(now())
  channel NotificationChannel

  alert Alert  @relation(fields: [alertId], references: [id], onDelete: Cascade)
  offer Offer? @relation(fields: [offerId], references: [id])

  @@map("alert_histories")
}

model PriceHistory {
  id        String   @id @default(uuid())
  programId String
  date      DateTime
  avgCpm    Decimal  @db.Decimal(10, 2)
  minCpm    Decimal  @db.Decimal(10, 2)
  source    String?
  createdAt DateTime @default(now())

  program LoyaltyProgram @relation(fields: [programId], references: [id])

  @@map("price_histories")
}

model SavedOffer {
  userId  String
  offerId String
  savedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@id([userId, offerId])
  @@map("saved_offers")
}

model ContentArticle {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  body        String
  category    String
  isProOnly   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("content_articles")
}

model UserMilesBalance {
  id        String   @id @default(uuid())
  userId    String
  programId String
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  program LoyaltyProgram @relation(fields: [programId], references: [id])

  @@unique([userId, programId])
  @@map("user_miles_balances")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  admin User @relation("AdminAuditLogs", fields: [adminId], references: [id])

  @@map("audit_logs")
}
