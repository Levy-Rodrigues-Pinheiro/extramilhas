# ─── Obrigatórias em prod (fail-fast se faltar NODE_ENV=production) ───
DATABASE_URL="postgresql://user:pass@host:5432/postgres"
DIRECT_URL="postgresql://user:pass@host:5432/postgres"
JWT_SECRET="gere-um-string-aleatorio-64-chars"
JWT_REFRESH_SECRET="outro-string-aleatorio-64-chars"

# ─── Base (opcionais com fallback) ────────────────────────────────
NODE_ENV="development"
PORT="3001"
API_PREFIX="api/v1"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS: vazio em dev = allow-all. Prod = whitelist interno.
# Override: "https://dominio1.com,https://dominio2.com"
CORS_ORIGINS=""

# ─── Integrações opcionais (no-op se ausente) ────────────────────

# Stripe (ver docs/STRIPE_SETUP.md)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PREMIUM_PRICE_ID=""
STRIPE_PREMIUM_ANNUAL_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""
STRIPE_PRO_ANNUAL_PRICE_ID=""
FRONTEND_URL="http://localhost:3000"

# Anthropic (Intel Agent LLM extraction)
ANTHROPIC_API_KEY=""

# Twilio (WhatsApp alerts + SMS verify)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
TWILIO_SMS_FROM="+1xxxxxxxxxx"

# Analytics
POSTHOG_API_KEY=""
POSTHOG_HOST="https://us.i.posthog.com"

# Error tracking
SENTRY_DSN=""

# Expo Push
EXPO_ACCESS_TOKEN=""

# Scraper separate service
SCRAPER_URL="http://localhost:3002"
SCRAPER_TIMEOUT_MS="15000"
SCRAPER_ENABLED="true"
SCRAPER_WEBHOOK_SECRET=""

# Scheduler (default ON em production)
SCHEDULER_ENABLED=""
INTEL_AGENT_ENABLED=""

# Flight cache
FLIGHT_CACHE_FRESH_HOURS="24"
FLIGHT_CACHE_STALE_HOURS="168"
FLIGHT_CACHE_LRU_MAX="1000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# SendGrid (forgot-password)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@milhasextras.com.br"

# Admin seed (obrigatório em prod)
SEED_ADMIN_PASSWORD=""

# Redis (BullMQ)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# Log level: trace | debug | info | warn | error
LOG_LEVEL="info"
