// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String   @id @default(uuid())
  email                 String   @unique
  name                  String
  passwordHash          String?
  authProvider          String   @default("EMAIL")
  subscriptionPlan      String   @default("FREE")
  subscriptionExpiresAt DateTime?
  stripeCustomerId      String?  @unique // linka User <-> customer Stripe p/ webhooks de cancel/update
  trialStartedAt        DateTime? // único trial por conta; preenchido quando user ativa 7d grátis
  refreshToken          String?
  whatsappPhone         String?
  isAdmin               Boolean  @default(false)
  // Perfil público (opt-in). Se publicUsername != null, user aparece em /u/:username
  publicUsername        String?  @unique
  publicBio             String?
  publicAvatarUrl       String?
  // Privacidade: user controla o que aparece no perfil público
  publicShowLeaderboard Boolean  @default(false)
  publicShowGuides      Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  preferences   UserPreference?
  alerts        Alert[]
  savedOffers   SavedOffer[]
  notifications Notification[]
  milesBalances UserMilesBalance[]
  auditLogs     AuditLog[]         @relation("AdminAuditLogs")
  familyMembers FamilyMember[]
  bonusReports  BonusReport[]      @relation("BonusReportReporter")
  bonusReviews  BonusReport[]      @relation("BonusReportReviewer")
  deviceTokens  DeviceToken[]

  // Referral — cada user tem código único pra dividir; pode ter sido referido
  // por outro user. Ambos ganham bônus quando o novo user fica ativo.
  referralCode  String?  @unique
  referredById  String?
  referredBy    User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referrals     User[]   @relation("UserReferrals")

  // Última atividade detectada (push register, abertura — proxy). Alimenta
  // reactivation cron sem precisar instrumentar login em toda query.
  lastActiveAt  DateTime?

  userMissions  UserMission[]

  @@map("users")
}

model UserPreference {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  preferredPrograms      String   @default("[]")
  preferredOrigins       String   @default("[]")
  preferredDestinations  String   @default("[]")
  targetCpm              Float    @default(25.00)
  // Preferências de notificação (bonus reports aprovados)
  // notifyBonus=true é default friendly — user desliga se quiser
  notifyBonus            Boolean  @default(true)
  // JSON array de pares "from:to" (ex: ["livelo:smiles","esfera:smiles"])
  // Vazio = recebe notificação de TODOS os bônus
  notifyProgramPairs     String   @default("[]")
  // Canais extras (push é padrão sempre-on se notifyBonus=true)
  notifyWhatsApp         Boolean  @default(false)
  whatsappVerifiedAt     DateTime? // só envia WhatsApp depois de verificar o número
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model LoyaltyProgram {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  logoUrl       String?
  websiteUrl    String?
  avgCpmCurrent Float    @default(25.00)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  offers              Offer[]
  priceHistory        PriceHistory[]
  milesBalances       UserMilesBalance[]
  transfersFrom       TransferPartnership[] @relation("TransferFrom")
  transfersTo         TransferPartnership[] @relation("TransferTo")
  familyBalances      FamilyMemberBalance[]
  awardCharts         AwardChart[]

  @@map("loyalty_programs")
}

model Offer {
  id               String    @id @default(uuid())
  programId        String
  type             String
  title            String
  description      String?
  cpm              Float
  classification   String
  sourceUrl        String?
  affiliateUrl     String?
  startsAt         DateTime?
  expiresAt        DateTime?
  isActive         Boolean   @default(true)
  isDeleted        Boolean   @default(false)
  metadata         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  program        LoyaltyProgram  @relation(fields: [programId], references: [id])
  savedByUsers   SavedOffer[]
  alertHistories AlertHistory[]

  @@index([programId])
  @@index([isActive, isDeleted])
  @@index([isActive, isDeleted, cpm]) // feed ordenado por CPM
  @@index([isActive, isDeleted, createdAt]) // feed ordenado por recência
  @@index([programId, isActive, isDeleted]) // listagem por programa
  @@index([type])
  @@index([classification])
  @@index([cpm])
  @@index([createdAt])
  @@index([expiresAt])
  @@map("offers")
}

model Alert {
  id              String    @id @default(uuid())
  userId          String
  type            String
  conditions      String    @default("{}")
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  history AlertHistory[]

  @@index([userId])
  @@index([isActive])
  @@map("alerts")
}

model AlertHistory {
  id      String   @id @default(uuid())
  alertId String
  offerId String?
  sentAt  DateTime @default(now())
  channel String

  alert Alert  @relation(fields: [alertId], references: [id], onDelete: Cascade)
  offer Offer? @relation(fields: [offerId], references: [id])

  @@index([alertId])
  @@index([sentAt])
  @@map("alert_histories")
}

model PriceHistory {
  id        String   @id @default(uuid())
  programId String
  date      DateTime
  avgCpm    Float
  minCpm    Float
  source    String?
  createdAt DateTime @default(now())

  program LoyaltyProgram @relation(fields: [programId], references: [id])

  @@index([programId, date])
  @@index([programId])
  @@index([date])
  @@map("price_histories")
}

model SavedOffer {
  userId  String
  offerId String
  savedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@id([userId, offerId])
  @@map("saved_offers")
}

model ContentArticle {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  body        String
  category    String
  isProOnly   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("content_articles")
}

model UserMilesBalance {
  id                     String    @id @default(uuid())
  userId                 String
  programId              String
  balance                Int       @default(0)
  expiresAt              DateTime?
  // Última vez que mandamos push pra esse saldo por expiração. Cron diário
  // filtra: só envia se null OU mais velho que 7d. Evita spam diário até
  // o vencimento real.
  lastExpirationAlertAt  DateTime?
  updatedAt              DateTime  @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  program LoyaltyProgram @relation(fields: [programId], references: [id])

  @@unique([userId, programId])
  // Acesso hot: arbitrage.service.ts faz findMany({where: {userId}}) a cada
  // request de oportunidades. Unique composta não serve pra userId solo.
  @@index([userId])
  @@index([lastExpirationAlertAt])
  @@map("user_miles_balances")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  data      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  entityType String
  entityId   String?
  before     String?
  after      String?
  createdAt  DateTime @default(now())

  admin User @relation("AdminAuditLogs", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
  @@map("audit_logs")
}

model TransferPartnership {
  id            String    @id @default(uuid())
  fromProgramId String
  toProgramId   String
  baseRate      Float     @default(1.0)
  currentBonus  Float     @default(0)
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  fromProgram LoyaltyProgram @relation("TransferFrom", fields: [fromProgramId], references: [id])
  toProgram   LoyaltyProgram @relation("TransferTo", fields: [toProgramId], references: [id])

  @@index([fromProgramId, toProgramId, isActive])
  @@map("transfer_partnerships")
}

model FamilyMember {
  id           String   @id @default(uuid())
  userId       String
  name         String
  relationship String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  balances FamilyMemberBalance[]

  @@index([userId])
  @@map("family_members")
}

model AwardChart {
  id              String   @id @default(uuid())
  programId       String
  origin          String
  destination     String
  destinationName String
  country         String
  cabinClass      String
  milesRequired   Int
  isDirectFlight  Boolean  @default(false)
  lat             Float?
  lng             Float?
  source          String   @default("manual")
  isActive        Boolean  @default(true)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  program LoyaltyProgram @relation(fields: [programId], references: [id])

  @@unique([programId, origin, destination, cabinClass])
  @@index([programId, origin, cabinClass, isActive])
  @@index([origin, destination, cabinClass, isActive])
  @@map("award_charts")
}

model BonusReport {
  id              String    @id @default(uuid())
  // Quem reportou (opcional — permite anônimo via email)
  reporterId      String?
  reporterEmail   String?
  // Se veio do Intel Agent, referencia a source pra calcular accuracy
  intelSourceId   String?
  // Dados do bônus reportado (slugs de programa)
  fromProgramSlug String
  toProgramSlug   String
  bonusPercent    Float
  expiresAt       DateTime?
  // Comprovação opcional (link de print, screenshot URL)
  screenshotUrl   String?
  // Texto livre do reporter
  notes           String?
  // Workflow
  status          String    @default("PENDING") // PENDING | APPROVED | REJECTED | DUPLICATE
  adminNotes      String?
  reviewedAt      DateTime?
  reviewedById    String?
  // Quando aprovado, gera (ou atualiza) uma TransferPartnership
  partnershipId   String?
  createdAt       DateTime  @default(now())

  reporter User? @relation("BonusReportReporter", fields: [reporterId], references: [id])
  reviewer User? @relation("BonusReportReviewer", fields: [reviewedById], references: [id])

  @@index([status, createdAt])
  @@index([reporterId])
  @@index([fromProgramSlug, toProgramSlug])
  @@index([intelSourceId, status]) // accuracy queries por source
  @@map("bonus_reports")
}

// Device tokens para push notifications (Expo Push).
// Um user pode ter múltiplos (celular + tablet + web). Um device pode ser
// anônimo (userId=null) — vira associado se logar depois via re-register.
model DeviceToken {
  id         String   @id @default(uuid())
  userId     String?
  token      String   @unique // ExponentPushToken[xxx]
  platform   String   // 'android' | 'ios' | 'web'
  appVersion String?
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([lastUsedAt])
  @@map("device_tokens")
}

// ─── Intel Agent: crawlers inteligentes ──────────────────────────────
// Fontes que o agente varre (sites, blogs, landing pages). Admin edita
// sem precisar deploy. Cada source tem um run-log no IntelAgentRun.

model IntelSource {
  id            String   @id @default(uuid())
  name          String   // "Melhores Destinos - promoções"
  url           String
  // "html" = baixa página inteira; "rss" = feed XML; "api" = endpoint
  sourceType    String   @default("html")
  // Regex/seletor opcional pra extrair só o trecho relevante (reduz
  // tokens enviados ao LLM). Ex: "main.post-content" ou "div.promos"
  scopeSelector String?
  isActive      Boolean  @default(true)
  // Rate limit: só refaz extraction se última run >minIntervalMin atrás
  minIntervalMin Int     @default(120)
  lastRunAt     DateTime?
  // Custo acumulado em USD (atualizado por run)
  costUsd       Float    @default(0)
  // SHA-256 do texto extraído na última run bem-sucedida. Se o hash novo
  // bate o anterior, skippa LLM call (página não mudou, não tem bônus novo).
  // Economia típica: ~60-80% dos calls (blogs atualizam 1x/semana).
  lastContentHash String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  runs IntelAgentRun[]

  @@index([isActive, lastRunAt])
  @@map("intel_sources")
}

model IntelAgentRun {
  id              String   @id @default(uuid())
  sourceId        String
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  status          String   // "running" | "ok" | "skipped" | "error"
  // Métricas
  htmlBytes       Int?
  extractedCount  Int      @default(0) // bônus extraídos pelo LLM
  newReportsCount Int      @default(0) // após dedupe
  costUsd         Float    @default(0)
  errorMessage    String?
  // Debug: primeiros 500 chars do trecho enviado ao LLM
  inputPreview    String?
  // Output bruto do LLM (JSON array de bonuses extraídos) pra debug/auditoria
  // Limitado no código a 5000 chars. Se LLM produziu lixo, admin debuga.
  llmOutputRaw    String?

  source IntelSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, startedAt])
  @@index([status, startedAt])
  @@map("intel_agent_runs")
}

model WaitlistSignup {
  id            String   @id @default(uuid())
  email         String
  whatsappPhone String?
  source        String?  // ex: "instagram-ad-v1", "blog-arbitragem", "organic"
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  // Quanto a pessoa diz estar disposta a pagar (R$/mês)
  willingToPay  Float?
  // Mensagem livre na captura
  message       String?
  // Quando foi convertido em usuário pago
  convertedAt   DateTime?
  // Se ainda não convertido, contador de quantos emails ela recebeu
  emailsSent    Int      @default(0)
  createdAt     DateTime @default(now())

  @@unique([email])
  @@index([source])
  @@index([createdAt])
  @@index([convertedAt])
  @@map("waitlist_signups")
}

model SearchLog {
  id          String   @id @default(uuid())
  origin      String
  destination String
  departDate  String
  cabinClass  String
  passengers  Int      @default(1)
  userId      String?  // null se anônimo
  // Resultado agregado: quantos retornaram, melhor dataQuality, fonte principal
  resultCount Int      @default(0)
  topSource   String?  // "cache_fresh" | "manual" | "synthetic_estimate"
  isLive      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([origin, destination, departDate, cabinClass])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("search_logs")
}

model LiveFlightCache {
  id            String   @id @default(uuid())
  programSlug   String   // smiles, tudoazul, latampass
  origin        String
  destination   String
  departDate    String   // yyyy-mm-dd
  cabinClass    String   // economy, business, first
  milesRequired Int
  taxBrl        Float    @default(0)
  airline       String?
  flightNumber  String?
  departureTime String?
  arrivalTime   String?
  duration      String?
  stops         Int      @default(0)
  rawPayload    String?  // JSON bruto do scraper
  fetchedAt     DateTime @default(now())
  expiresAt     DateTime // TTL: agora + 24h (config)

  @@unique([programSlug, origin, destination, departDate, cabinClass, flightNumber])
  @@index([origin, destination, departDate, cabinClass, expiresAt])
  @@index([expiresAt])
  @@map("live_flight_cache")
}

// ─── Gamification: Missions ────────────────────────────────────────────
// Missions são "desafios" semanais/mensais que admin cria e users completam
// pra ganhar dias Premium. Reforçam crowdsource + retention sem pagar $.

model Mission {
  id            String   @id @default(uuid())
  slug          String   @unique // "report-3-bonuses-week"
  title         String
  description   String
  // Tipos suportados (validados no service):
  //   "bonus_reports_approved" | "balance_programs_added" | "referrals_applied"
  targetType    String
  targetCount   Int
  rewardDays    Int      @default(7) // dias Premium
  isActive      Boolean  @default(true)
  validFrom     DateTime @default(now())
  validTo       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userMissions  UserMission[]

  @@index([isActive, validFrom])
  @@map("missions")
}

model UserMission {
  id             String    @id @default(uuid())
  userId         String
  missionId      String
  progress       Int       @default(0)
  completedAt    DateTime?
  rewardClaimedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId])
  @@index([userId, completedAt])
  @@map("user_missions")
}

/// Feature flags com rollout gradual. Admin edita sem deploy.
/// Rollout: 0-100 (percentual de users). Hash estável do userId decide se
/// user está no bucket. Se user é null, aplica pra todos anônimos.
/// Overrides: allowlist de userIds que sempre vêem true (testers).
model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique // "new-home-layout", "ab-paywall-copy-v2"
  description String
  // "off" = sempre false; "on" = sempre true; "rollout" = usa percentage
  mode        String   @default("off")
  percentage  Int      @default(0) // 0-100
  // JSON array de userIds que sempre vêem ON (pra QA/staff)
  allowlist   String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}

/// A/B tests — variantes de um experimento. Cada user cai numa variante
/// determinística por hash(userId + experimentKey). Tracking de exposure
/// + conversão fica no event log (analytics module).
model Experiment {
  id          String   @id @default(uuid())
  key         String   @unique // "paywall-copy-2026-04"
  description String
  // JSON array: [{"name":"control","weight":50},{"name":"variant_a","weight":50}]
  variants    String   @default("[]")
  isActive    Boolean  @default(true)
  startedAt   DateTime @default(now())
  endedAt     DateTime?

  @@map("experiments")
}

/// Daily streak — cada dia que user abre o app conta. Quebra se pula
/// 1 dia. Recompensa: 7d = 1d Premium grátis; 30d = 7d Premium.
model UserStreak {
  id               String   @id @default(uuid())
  userId           String   @unique
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  lastActiveDate   DateTime // yyyy-mm-dd (usa 00:00 UTC pra simplicidade)
  freezesAvailable Int      @default(1) // 1 "freeze" por mês protege streak de 1 dia perdido
  // Milestones já reivindicados pra não pagar 2x. JSON array: [7, 30, 100]
  milestonesClaimed String  @default("[]")
  updatedAt        DateTime @updatedAt

  @@map("user_streaks")
}

/// UGC: guias escritos pela comunidade. Alta ROI de SEO — páginas públicas
/// indexadas no Next landing. Moderação: admin aprova antes de publicar.
model UserGuide {
  id          String   @id @default(uuid())
  authorId    String
  title       String
  slug        String   @unique // URL-safe, gerado no service
  summary     String   // <280 chars — aparece em listagens
  body        String   // Markdown
  tags        String   @default("[]") // JSON array ["smiles", "paris"]
  coverImage  String?  // URL opcional
  status      String   @default("DRAFT") // DRAFT | PENDING_REVIEW | PUBLISHED | REJECTED
  rejectionReason String?
  upvoteCount Int      @default(0)
  viewCount   Int      @default(0)
  publishedAt DateTime?
  reviewedAt  DateTime?
  reviewedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  upvotes     GuideUpvote[]

  @@index([status, publishedAt])
  @@index([authorId])
  @@map("user_guides")
}

model GuideUpvote {
  id        String   @id @default(uuid())
  guideId   String
  userId    String
  createdAt DateTime @default(now())

  guide     UserGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@unique([guideId, userId])
  @@index([userId])
  @@map("guide_upvotes")
}

/// Tickets de suporte — user abre, admin responde. Reduz pressão no
/// WhatsApp/e-mail + cria audit trail natural.
model SupportTicket {
  id          String   @id @default(uuid())
  userId      String
  subject     String
  category    String   @default("GENERAL") // GENERAL | BILLING | BUG | FEATURE | ACCOUNT
  status      String   @default("OPEN")    // OPEN | AWAITING_USER | RESOLVED | CLOSED
  priority    String   @default("NORMAL")  // LOW | NORMAL | HIGH | URGENT
  // Admin que tá cuidando (null = backlog)
  assignedTo  String?
  resolvedAt  DateTime?
  lastActivityAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    SupportMessage[]

  @@index([userId, status])
  @@index([status, priority])
  @@index([assignedTo, status])
  @@map("support_tickets")
}

/// Cartões de crédito catalogados. Admin popula. Usado pelo recommender
/// que sugere qual cartão tem melhor ROI pra gasto médio do user.
///
/// Modelo brasileiro: cada cartão acumula em 1 ou mais programas de pontos
/// com taxa variável por categoria (restaurante 1.5x, etc).
model CreditCard {
  id              String   @id @default(uuid())
  name            String   // "Itaú Personnalité Gold"
  brand           String   // "Visa" | "Mastercard" | "Amex"
  issuer          String   // "Itaú" | "Santander" | "Amex"
  tier            String   @default("STANDARD") // STANDARD | GOLD | PLATINUM | BLACK
  annualFeeBrl    Int      @default(0) // R$ em centavos (0 = sem anuidade)
  // Programa principal que acumula (livelo, esfera, etc)
  mainProgramSlug String
  // Pontos por R$1 gasto (base)
  pointsPerBrl    Float    @default(1.0)
  // Multiplier por categoria (JSON: {"restaurante": 1.5, "viagem": 2.0})
  categoryBonuses String   @default("{}")
  // Bônus de boas-vindas (pontos ganhos ao atingir X de gasto nos primeiros 90d)
  welcomePoints   Int      @default(0)
  welcomeSpendBrl Int      @default(0) // centavos
  // Renda mínima exigida (centavos)
  minIncomeBrl    Int      @default(0)
  logoUrl         String?
  officialUrl     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive, tier])
  @@index([mainProgramSlug])
  @@map("credit_cards")
}

/// API keys pros devs/blogs/parceiros consumirem dados via /public/*.
/// Rate limit por tier. Usage contado pra billing futuro.
model ApiKey {
  id             String   @id @default(uuid())
  // Owner user (se user-created) ou admin (se parceiro)
  ownerId        String
  name           String   // "Blog Passageiro de Primeira"
  // Hash do secret (nunca armazena plaintext após criação)
  keyHash        String   @unique
  // Prefix público visível (primeiros 8 chars do secret) pra UX de listagem
  keyPrefix      String
  // "free" = 100 req/dia; "starter" = R$49/mês 10k/dia; "business" = R$299/mês 100k/dia
  tier           String   @default("free")
  isActive       Boolean  @default(true)
  lastUsedAt     DateTime?
  // Contagem cumulativa — reseta todo mês 1
  requestsThisMonth Int   @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ownerId])
  @@index([keyHash, isActive])
  @@map("api_keys")
}

/// Personal notes/reminders. User anota "quando Smiles abrir bônus 150%,
/// transferir 30k" e define reminder opcional. Zero scope de compartilhamento.
model UserNote {
  id          String   @id @default(uuid())
  userId      String
  title       String
  body        String
  // Opcional: data pra gerar notificação push no dia/hora
  remindAt    DateTime?
  remindSent  Boolean  @default(false)
  // Tag livre (programa, destino, etc)
  tag         String   @default("GERAL")
  isPinned    Boolean  @default(false)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, isArchived, isPinned])
  @@index([remindAt, remindSent])
  @@map("user_notes")
}

/// GroupBuy — users se organizam pra comprar pontos juntos numa promoção
/// (muitas vezes bônus aumenta em volume). Organizador cria; outros entram.
/// Quando fecha (ou atinge minPoints), organizador vê lista pra coordenar
/// off-platform (WhatsApp).
model GroupBuy {
  id            String   @id @default(uuid())
  organizerId   String
  programId     String // programa destino (Smiles, Latam, etc)
  title         String
  description   String
  targetPoints  Int // objetivo de pontos combinados
  minPoints     Int @default(10000) // threshold pra disparar "fechamos grupo"
  deadline      DateTime
  status        String   @default("OPEN") // OPEN | CLOSED | CANCELED
  contactMethod String @default("WHATSAPP") // WHATSAPP | EMAIL | IN_APP
  contactValue  String // número ou email do organizador
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  participants  GroupBuyParticipant[]

  @@index([status, deadline])
  @@index([programId, status])
  @@map("group_buys")
}

model GroupBuyParticipant {
  id         String   @id @default(uuid())
  groupBuyId String
  userId     String
  points     Int
  joinedAt   DateTime @default(now())

  groupBuy   GroupBuy @relation(fields: [groupBuyId], references: [id], onDelete: Cascade)

  @@unique([groupBuyId, userId])
  @@index([userId])
  @@map("group_buy_participants")
}

/// TripSwap — marketplace de troca de experiências de viagem com milhas.
/// User A diz "tenho voo+hotel pra Paris em Mar/26, quero trocar por
/// Tokyo em Jun/26". Matches manuais. App só facilita descoberta.
model TripSwap {
  id              String   @id @default(uuid())
  ownerId         String
  title           String
  description     String
  fromCity        String // IATA ou texto livre
  fromDate        DateTime
  toDate          DateTime
  // Que cidade/período ele QUER em troca. JSON pra flexibilidade.
  desiredInTrade  String // livre ("Qualquer Europa em Jun/26") ou JSON estruturado
  estimatedValue  Int // valor estimado em milhas da oferta
  status          String   @default("OPEN") // OPEN | NEGOTIATING | CLOSED
  contactMethod   String @default("WHATSAPP")
  contactValue    String
  viewCount       Int @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  interests       TripSwapInterest[]

  @@index([status, fromDate])
  @@index([ownerId])
  @@map("trip_swaps")
}

model TripSwapInterest {
  id          String   @id @default(uuid())
  tripSwapId  String
  userId      String
  message     String
  createdAt   DateTime @default(now())

  tripSwap    TripSwap @relation(fields: [tripSwapId], references: [id], onDelete: Cascade)

  @@unique([tripSwapId, userId])
  @@index([userId])
  @@map("trip_swap_interests")
}

/// SecurityEvent — log de eventos suspeitos pro anti-fraude. Cada event é
/// imutável, um comportamento = um row. Admin dashboard agrega pra
/// detectar padrões (ex: muitos REGISTER_FAIL mesmo IP = credential stuffing).
model SecurityEvent {
  id        String   @id @default(uuid())
  // LOGIN_FAIL | LOGIN_OK | REGISTER_OK | REGISTER_FAIL | PASSWORD_RESET |
  // ALERT_CREATE | RATE_LIMIT_HIT | SUSPICIOUS_PATTERN
  eventType String
  userId    String?  // null se anônimo/pré-login
  ipAddress String?
  userAgent String?
  // JSON livre com detalhes (ex: errorReason, duration, route)
  metadata  String?
  // Risk score 0-100 calculado pelo service (rule-based)
  riskScore Int      @default(0)
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([ipAddress, createdAt])
  @@index([userId, createdAt])
  @@index([riskScore, createdAt])
  @@map("security_events")
}

model SupportMessage {
  id          String   @id @default(uuid())
  ticketId    String
  // Quem escreveu — user ou admin (o mesmo user schema). Admin é detectado
  // via User.isAdmin no service quando monta resposta.
  authorId    String
  body        String
  // Pra admin fazer notas internas que user não vê
  isInternal  Boolean  @default(false)
  createdAt   DateTime @default(now())

  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@map("support_messages")
}

/// Goals — "quero 150k milhas Smiles até Dez/2025". App mostra progresso
/// + tempo médio histórico + sugere ações (transferências, bônus).
model UserGoal {
  id            String   @id @default(uuid())
  userId        String
  title         String
  // Programa alvo (opcional — pode ser genérico "milhas totais")
  programId     String?
  targetMiles   Int
  targetDate    DateTime
  // Snapshot do saldo quando goal foi criado (pra calcular delta)
  startingMiles Int      @default(0)
  isArchived    Boolean  @default(false)
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, isArchived])
  @@map("user_goals")
}

/// Forum threads — community básica. Posts são replies dentro da thread.
/// Moderation: isFlagged + hiddenAt pra soft-delete quando admin baniu.
model ForumThread {
  id          String   @id @default(uuid())
  authorId    String
  title       String
  body        String
  // Tag livre pra começar. Pode virar enum depois: ROTA, PROGRAMA, DUVIDA, BONUS
  tag         String   @default("GERAL")
  replyCount  Int      @default(0)
  upvoteCount Int      @default(0)
  isFlagged   Boolean  @default(false)
  hiddenAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts       ForumPost[]

  @@index([tag, createdAt])
  @@index([authorId])
  @@map("forum_threads")
}

model ForumPost {
  id        String   @id @default(uuid())
  threadId  String
  authorId  String
  body      String
  upvoteCount Int    @default(0)
  isFlagged Boolean  @default(false)
  hiddenAt  DateTime?
  createdAt DateTime @default(now())

  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([authorId])
  @@map("forum_posts")
}

/// Polls — enquete semanal. Admin cria. User vota 1x.
model Poll {
  id        String    @id @default(uuid())
  question  String
  // JSON array of {id, label}. Ex: [{"id":"a","label":"Smiles"},{"id":"b","label":"Latam"}]
  options   String
  isActive  Boolean   @default(true)
  endsAt    DateTime?
  createdAt DateTime  @default(now())

  votes     PollVote[]

  @@index([isActive, endsAt])
  @@map("polls")
}

model PollVote {
  id        String   @id @default(uuid())
  pollId    String
  userId    String
  optionId  String
  createdAt DateTime @default(now())

  poll      Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId, optionId])
  @@map("poll_votes")
}

/// Avaliação de uma transfer partnership (bônus) — user diz se "funcionou"
/// pra ele. Alimenta score de credibilidade das ofertas no feed.
/// 1 review por user por partnership (unique).
model OfferReview {
  id            String   @id @default(uuid())
  userId        String
  partnershipId String // TransferPartnership.id
  // Simples pra começar: "funcionou" / "não funcionou". Pode virar 1-5 estrelas depois.
  worked        Boolean
  comment       String?
  createdAt     DateTime @default(now())

  @@unique([userId, partnershipId])
  @@index([partnershipId])
  @@map("offer_reviews")
}

model FamilyMemberBalance {
  id             String    @id @default(uuid())
  familyMemberId String
  programId      String
  balance        Int       @default(0)
  expiresAt      DateTime?
  updatedAt      DateTime  @updatedAt

  member  FamilyMember   @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  program LoyaltyProgram @relation(fields: [programId], references: [id])

  @@unique([familyMemberId, programId])
  @@map("family_member_balances")
}
